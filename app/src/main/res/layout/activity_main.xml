<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ 连点器"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#E94560"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="8dp" />

        <!-- ===== 权限状态卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="权限状态"
                    android:textColor="#A0AEC0"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:paddingBottom="8dp" />

                <!-- 悬浮窗权限 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="悬浮窗权限"
                        android:textColor="#E2E8F0"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvStatusOverlay"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✗ 未授权"
                        android:textColor="#E74C3C"
                        android:textSize="14sp"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnOverlay"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="授权"
                        android:textSize="12sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:backgroundTint="#E94560" />
                </LinearLayout>

                <!-- 无障碍服务 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="无障碍服务"
                        android:textColor="#E2E8F0"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvStatusAccessibility"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✗ 未启用"
                        android:textColor="#E74C3C"
                        android:textSize="14sp"
                        android:layout_marginEnd="8dp" />

                    <Button
                        android:id="@+id/btnAccessibility"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="启用"
                        android:textSize="12sp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:backgroundTint="#E94560" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 连点速度卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="连点速度"
                        android:textColor="#A0AEC0"
                        android:textSize="12sp"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/tvCpsValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="10 次/秒"
                        android:textColor="#E94560"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekBarCps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:max="99"
                    android:progress="9"
                    android:progressTint="#E94560"
                    android:thumbTint="#E94560" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="1 次/秒"
                        android:textColor="#718096" android:textSize="11sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="100 次/秒"
                        android:textColor="#718096" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 点击坐标与区域卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="点击坐标（像素）"
                    android:textColor="#A0AEC0"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:paddingBottom="10dp" />

                <!-- X / Y -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="中心 X" android:textColor="#E2E8F0" android:textSize="13sp"
                            android:paddingBottom="4dp"/>
                        <EditText
                            android:id="@+id/etClickX"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:inputType="numberDecimal"
                            android:text="540"
                            android:textColor="#E2E8F0"
                            android:background="@drawable/bg_edit_text"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="中心 Y" android:textColor="#E2E8F0" android:textSize="13sp"
                            android:paddingBottom="4dp"/>
                        <EditText
                            android:id="@+id/etClickY"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:inputType="numberDecimal"
                            android:text="960"
                            android:textColor="#E2E8F0"
                            android:background="@drawable/bg_edit_text"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 区域宽 / 高 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="10dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="区域宽度" android:textColor="#E2E8F0" android:textSize="13sp"
                            android:paddingBottom="4dp"/>
                        <EditText
                            android:id="@+id/etAreaW"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:inputType="numberDecimal"
                            android:text="10"
                            android:textColor="#E2E8F0"
                            android:background="@drawable/bg_edit_text"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="区域高度" android:textColor="#E2E8F0" android:textSize="13sp"
                            android:paddingBottom="4dp"/>
                        <EditText
                            android:id="@+id/etAreaH"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:inputType="numberDecimal"
                            android:text="10"
                            android:textColor="#E2E8F0"
                            android:background="@drawable/bg_edit_text"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 触点半径卡片 ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="#16213E"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="触点半径"
                        android:textColor="#A0AEC0"
                        android:textSize="12sp"
                        android:textAllCaps="true" />

                    <TextView
                        android:id="@+id/tvRadiusValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 px"
                        android:textColor="#E94560"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/seekBarRadius"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:max="49"
                    android:progress="4"
                    android:progressTint="#E94560"
                    android:thumbTint="#E94560" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="1 px 精准"
                        android:textColor="#718096" android:textSize="11sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="50 px 大触点"
                        android:textColor="#718096" android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ===== 操作按钮 ===== -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="💾  保存参数"
            android:textSize="15sp"
            android:backgroundTint="#0F3460" />

        <Button
            android:id="@+id/btnStartFloat"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="▶  启动悬浮窗"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#E94560" />

        <Button
            android:id="@+id/btnStopFloat"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="■  停止并关闭"
            android:textSize="15sp"
            android:backgroundTint="#2D3748" />

        <!-- 帮助链接 -->
        <TextView
            android:id="@+id/tvHelp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="❓ 查看使用说明"
            android:textColor="#4A90E2"
            android:textSize="14sp"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="24dp" />

    </LinearLayout>
</ScrollView>
